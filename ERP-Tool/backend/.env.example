# Database Configuration
DATABASE_URL=mysql+pymysql://user:password@host:4000/database
# For Render, this will be automatically set from the database service

# Redis Configuration
# For local development: REDIS_URL=redis://localhost:6379
# For Render deployment: Set REDIS_URL to your Render Redis Internal URL
# Format: redis://red-xxxx:6379
# Get it from: Render Dashboard → Your Redis Service → Connect → Internal Redis URL
REDIS_URL=redis://localhost:6379

# MongoDB Configuration
# For local development: MONGODB_URI=mongodb://localhost:27017/erp_logs
# For Render deployment: Set MONGODB_URI to your MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
# Create free cluster at: https://cloud.mongodb.com
# Whitelist 0.0.0.0/0 under Network Access
MONGODB_URI=mongodb://localhost:27017/erp_logs

# Application Configuration
NODE_ENV=production
SECRET_KEY=your-secret-key-here
CORS_ORIGINS=https://your-frontend-domain.com

# TiDB Cloud Configuration (Optional - if using external TiDB)
# DATABASE_URL=mysql+pymysql://root:password@gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com:4000/erp_db
