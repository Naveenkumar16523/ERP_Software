# MongoDB Connection (Primary database for RBAC/Auth)
MONGODB_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB_NAME="erp_database"

# Redis Cache Connection (Optional but recommended)
REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# JWT Secrets for Authentication
# Generate securely with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="REPLACE_WITH_64_CHAR_RANDOM_HEX"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX"

# CORS Allowed Origins
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:5173,https://your-production-app.vercel.app"

# Application Environment (development or production)
NODE_ENV="development"
