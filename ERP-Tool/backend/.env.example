# ─────────────────────────────────────────────────────────────────────────────
# ERP Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Aiven MySQL) ────────────────────────────────────────────────────
# Format: mysql://user:password@host:port/dbname?ssl-mode=REQUIRED
MYSQL_URL=mysql://avnadmin:YOUR_PASSWORD@mysql-xxxx.aivencloud.com:PORT/defaultdb?ssl-mode=REQUIRED

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
SECRET_KEY=change-me-to-yet-another-secret

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development

# ── CORS (comma-separated list of allowed origins) ───────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Optional: Redis (leave blank to disable caching) ─────────────────────────
REDIS_URL=

# ── Optional: Sentry error tracking ──────────────────────────────────────────
SENTRY_DSN=

# ── Emergency CEO Reset (used by POST /api/v1/auth/reset-ceo) ─────────────────
RESET_SECRET=emergency-reset-2024
