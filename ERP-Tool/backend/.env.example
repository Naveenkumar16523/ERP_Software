# Database Configuration
DATABASE_URL=mysql+pymysql://user:password@host:4000/database
# For Render, this will be automatically set from the database service

# Redis Configuration
REDIS_URL=redis://localhost:6379
# For Render, this will be automatically set from the Redis service

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
# For Render, this will be automatically set from the MongoDB service

# Application Configuration
NODE_ENV=production
SECRET_KEY=your-secret-key-here
CORS_ORIGINS=https://your-frontend-domain.com

# TiDB Cloud Configuration (Optional - if using external TiDB)
# DATABASE_URL=mysql+pymysql://root:password@gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com:4000/erp_db
