# FastAPI port
PORT=8000

# OpenAI API Credentials for LangChain/GPT-4 integrations
OPENAI_API_KEY=your-openai-api-key-here

# CORS restriction configuration (wildcard * is disallowed)
ALLOWED_ORIGIN=http://localhost:5173

# Database connection URL for dynamic queries
DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/erp_db
